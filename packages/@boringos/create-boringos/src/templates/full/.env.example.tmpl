# BoringOS — {{name}}
#
# Copy this file to .env and fill in the values.
# DATABASE_URL and PG_EMBEDDED control the database backend.

# ── Database ──────────────────────────────────────────────────────────────────
# External Postgres (production / team dev). Create the database first:
#   psql -c "CREATE DATABASE boringos;" postgres://user:pass@host:5432/postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/boringos

# Set PG_EMBEDDED=false to require DATABASE_URL (no embedded fallback).
# Omit both to use the embedded dev Postgres (zero-config, data in .data/postgres).
# PG_EMBEDDED=false

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required in production. Any random string works (openssl rand -hex 32).
# AUTH_SECRET=change-me

# ── Queue (BullMQ) ────────────────────────────────────────────────────────────
# Redis connection string. Enables BullMQ job queue when set.
# REDIS_URL=redis://localhost:6379

# ── Memory (Hebbs) ────────────────────────────────────────────────────────────
# HEBBS_ENDPOINT=https://your-hebbs-instance.com
# HEBBS_API_KEY=your-api-key
# HEBBS_WORKSPACE=your-workspace

# ── Slack connector ───────────────────────────────────────────────────────────
# SLACK_SIGNING_SECRET=your-signing-secret

# ── Google connector ──────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
